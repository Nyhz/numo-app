<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.finances.advisor-chat-compact</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/nyhzdev/devroom/battlefields/finances/scripts/cron-advisor-chat-compact.sh</string>
  </array>

  <!-- Lunes 08:50 hora local (Madrid), antes del scan de las 09:00. Weekday 1 = lunes. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key><integer>1</integer>
    <key>Hour</key><integer>8</integer>
    <key>Minute</key><integer>50</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/nyhzdev/.finances/logs/advisor-chat-compact.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/nyhzdev/.finances/logs/advisor-chat-compact.log</string>
</dict>
</plist>
