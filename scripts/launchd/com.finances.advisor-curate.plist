<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.finances.advisor-curate</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/nyhzdev/devroom/battlefields/finances/scripts/cron-advisor-curate.sh</string>
  </array>

  <!-- Domingo 23:30 hora local (Madrid). Weekday 0 = domingo. -->
