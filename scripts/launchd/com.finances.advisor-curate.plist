    <key>Hour</key><integer>23</integer>
    <key>Minute</key><integer>30</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/nyhzdev/.finances/logs/advisor-curate.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/nyhzdev/.finances/logs/advisor-curate.log</string>
