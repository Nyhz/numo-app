# Path to the SQLite database file (relative to repo root).
DATABASE_URL=data/finances.db

# Legacy alias used in SPEC §9; keep in sync with DATABASE_URL.
DB_PATH=./data/finances.db

# Shared secret required by the price-sync cron route (src/app/api/cron/sync-prices).
CRON_SECRET=change-me

# Optional override for the Yahoo Finance client User-Agent header.
YAHOO_USER_AGENT=

# CoinGecko API key for crypto price sync. Free "demo" tier key works.
# Obtain at https://www.coingecko.com/en/developers/dashboard.
COINGECKO_API_KEY=

# Display name shown in the UI shell (top nav brand).
NEXT_PUBLIC_APP_NAME="Patrimonio"

# Port Next.js binds to in dev/start.
PORT=3200

# ── Asesor Financiero AI ──────────────────────────────────────────────────────
# Token OAuth de larga duración de Claude Code (`claude setup-token`). Enruta la
# facturación al crédito de la suscripción Max. NO definir ANTHROPIC_API_KEY a la
# vez: gana en precedencia y se saltaría el crédito.
CLAUDE_CODE_OAUTH_TOKEN=

# Kill switch del asesor (chat + scans). "false" lo desactiva por completo.
ADVISOR_ENABLED=true

# Modelos.
ADVISOR_CHAT_MODEL=claude-opus-4-8
ADVISOR_SCAN_MODEL=claude-sonnet-4-6

# Presupuestos de tamaño (bytes) de los ficheros de memoria.
ADVISOR_DIGEST_MAX_BYTES=8192
ADVISOR_PROFILE_MAX_BYTES=4096

# Report matinal por Telegram (tras el scan de las 09:00). Bot API directa.
ADVISOR_TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
